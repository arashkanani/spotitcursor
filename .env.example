# Copy to .env for local development (optional)
PORT=3001
NODE_ENV=development

# Render: set in dashboard → Environment
# PUBLIC_URL=https://your-app.onrender.com
# DATA_DIR=/var/data

# Auth (required in production for sign-in)
# SESSION_SECRET=use-a-long-random-string-at-least-16-chars
# GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
# Admin dashboard (/admin) — comma-separated emails
ADMIN_EMAILS=admin123456789@yahoo.com
# Optional one-time bootstrap on server start (set on Render, then remove password var):
# ADMIN_BOOTSTRAP_EMAIL=admin123456789@yahoo.com
# ADMIN_BOOTSTRAP_PASSWORD=your-secure-password

# Optional
# MAX_PLAYERS=120
# ROUND_TIMEOUT_MS=60000
# LEGACY_SHAPES_DIR=C:\path\to\old\shape\assets
